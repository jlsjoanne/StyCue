{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Issuer": "StyCue.Api",
    "Audience": "StyCue.Client",
    "AccessTokenMinutes": 120
  },
  "Cors": {
    "Policy": "All",
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:3001",
      "http://localhost:5173",
      "http://localhost:5174",
      "https://stycue.vercel.app"
    ]
  },
  "GoogleAuth": {
    "ClientId": ""
  },
  "ApiDocs": {
    "Enabled": true,
    "Title": "StyCue API",
    "Version": "v1",
    "Route": "/api-docs"
  },
  "BlobStorage": {
    "ContainerName": "stycue-image"
  },
  "Points": {
    "DailyRewardPoints": 10,
    "MinCommissionPoints": 50,
    "MinCommissionBoostPoints": 10,
    "NoCommentRefundPercent": 90,
    "NoCommentFeePercent": 10,
    "DefaultCommissionExpireDays": 7,
    "DefaultCommissionExtendDays": 7,
    "RegistrationRewardPoints": 50
  }
}
