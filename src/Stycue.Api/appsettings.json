{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Issuer": "StyCue.Api",
    "Audience": "StyCue.Client",
    "AccessTokenMinutes": 120
  },
  "Cors": {
    "Policy": "All",
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:3001",
      "http://localhost:5173",
      "http://localhost:5174",
      "https://stycue.vercel.app"
    ]
  },
  "GoogleAuth": {
    "ClientId": ""
  },
  "ApiDocs": {
    "Enabled": true,
    "Title": "StyCue API",
    "Version": "v1",
    "Route": "/api-docs"
  },
  "BlobStorage": {
    "ContainerName": "stycue-image"
  },
  "Points": {
    "DailyRewardPoints": 10,
    "MinCommissionPoints": 50,
    "MinCommissionBoostPoints": 10,
    "RefundPercent": 90,
    "FeePercent": 10,
    "DefaultCommissionExpireDays": 7,
    "DefaultCommissionExtendDays": 7,
    "RegistrationRewardPoints": 50,
    "EarlyCloseLimitHours": 12
  },
  "Ecpay": {
    "Environment": "Stage",
    "MerchantId": "",
    "HashKey": "",
    "HashIV": "",
    "PaymentActionUrl": "https://payment-stage.ecpay.com.tw/Cashier/AioCheckOut/V5",
    "ReturnUrl": "https://stycue.rocket-coding.com/api/payments/ecpay/return",
    "ClientBackUrl": "https://stycue.vercel.app/payment-result",
    "QueryTradeInfoUrl": "https://payment-stage.ecpay.com.tw/Cashier/QueryTradeInfo/V5"
  }
}
